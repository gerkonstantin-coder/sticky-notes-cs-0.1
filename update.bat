@echo off
chcp 65001 >nul

echo.
echo ╔══════════════════════════════════════════════════════════════════════╗
echo ║           Sticky Notes - Обновление репозитория                      ║
echo ╚══════════════════════════════════════════════════════════════════════╝
echo.

cd /d "%~dp0"

:: Проверяем наличие .git
if not exist ".git" (
    echo [ОШИБКА] Это не git репозиторий!
    echo.
    echo Клонируйте проект заново:
    echo git clone https://github.com/gerkonstantin-coder/sticky-notes-cs-0.1.git
    echo.
    pause
    exit /b 1
)

echo Обновление с GitHub...
echo.

:: Получаем изменения
git fetch origin

:: Проверяем есть ли изменения
git diff --quiet HEAD origin/main
if errorlevel 1 (
    echo Найдены обновления. Загрузка...
    git pull origin main
    
    echo.
    echo ╔══════════════════════════════════════════════════════════════════════╗
    echo ║                    ✅ Обновление завершено!                          ║
    echo ╚══════════════════════════════════════════════════════════════════════╝
) else (
    echo.
    echo ╔══════════════════════════════════════════════════════════════════════╗
    echo ║              У вас уже последняя версия                              ║
    echo ╚══════════════════════════════════════════════════════════════════════╝
)

echo.
pause
